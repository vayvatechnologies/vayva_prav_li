        </VBox>

        <beginButton>
            <Button text="Save"
                    type="Emphasized"
                    press="onDialogSave"/>
        </beginButton>

        <endButton>
            <Button text="Cancel"
                    press="onDialogCancel"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>