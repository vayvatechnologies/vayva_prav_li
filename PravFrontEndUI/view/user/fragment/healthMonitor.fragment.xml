  <core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        title="Health Monitor"
        
        draggable="true" contentWidth="{= ${device>/system/phone} ? '90%' : '50%' }"
        resizable="true" afterOpen=".onAfterOpenHealthMonitor"
        afterClose=".onAfterCloseHealthMonitor"
        class=" sapUiResponsivePadding sapUiResponsivePadding--content">
<!-- stretch="{= ${device>/system/phone} }" stretchOnPhone="true"  -->
        <!-- TOP RIGHT CLOSE ICON -->
        <customHeader>
            <Bar>
                <contentMiddle>
                    <Title text="Health Monitor" />
                </contentMiddle>
                <contentRight>
                    <Button
                        icon="sap-icon://decline"
                        type="Transparent"
                        press=".onCloseHealthMonitor" />
                </contentRight>
            </Bar>
        </customHeader>

        <!-- DIALOG CONTENT -->
        <content class="sapUiSmallMarginTop sapUiSmallMarginBottom">
              <VBox class="sapUiTinyMarginBegin sapUiTinyMarginEnd">

                    <!-- WATER -->
                    <Panel headerText="💧 Water Intake">
                        <VBox>
                             <HBox justifyContent="SpaceBetween">
                              
                            <Text text="Liters Consumed (0 – 15 L)" />
                             <ObjectStatus
                                text="Target:  {oUserDetailsModel>/daily_water_goal_l} L"
                                state="Information" />
                                 </HBox>
                            <Slider id="healthMonitor_waters"
                                min="0"
                                max="15"
                                step="0.5"
                                value="{/water}"
                                showAdvancedTooltip="true"
                                width="100%" />
                           
                        </VBox>
                    </Panel>

                    <!-- SLEEP -->
                    <Panel headerText="😴 Sleep Duration"  >
                        <VBox>
                            <HBox justifyContent="SpaceBetween">
                                 <Text text="Sleep Hours (0 – 15 hrs)" />
                             <ObjectStatus
                                text="Target: {oUserDetailsModel>/daily_sleep_goal_hr} hrs"
                                state="Information" />
                        </HBox>
                            <Slider  id="healthMonitor_sleep"
                                min="0"
                                max="15"
                                step="0.5"
                                value="{/sleep}"
                                showAdvancedTooltip="true"
                                width="100%" />
                           
                        </VBox>
                    </Panel>

                    <!-- STEPS -->
                    <Panel headerText="👟 Steps Walked">
                        <VBox>
                            <HBox justifyContent="SpaceBetween">
                            <Text text="Steps Count" />
                             <ObjectStatus
                                text="Target: {oUserDetailsModel>/daily_steps_goal} steps"
                                state="Information" />
                                </HBox> 
                            <StepInput  id="healthMonitor_steps"
                                min="0"
                                max="25000"
                                step="500"
                                value="{/steps}"
                                width="100%" />
                           
                        </VBox>
                    </Panel>

                   

                </VBox>
   
            <!-- Paste your IconTabBar / Inputs UI here -->
        </content>

        <!-- FOOTER BUTTONS -->
        

		<beginButton>
<Button
                text="Save Health Data"
                type="Success"
                icon="sap-icon://save"
                press=".onSaveHealthData" />		</beginButton>

        <endButton>
            

            <Button
                text="Close" type="Reject"
                icon="sap-icon://decline"
                press=".onCloseHealthMonitor" />
        </endButton>

    </Dialog>
</core:FragmentDefinition>
