<mvc:View
    controllerName="sap.ui.demo.toolpageapp.controller.AppInfo.privacyPolicy"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc">

    <Page showHeader="true" title="Privacy Policy">
        <landmarkInfo>
            <PageAccessibleLandmarkInfo
                rootRole="Region"
                rootLabel="{i18n>Privacy_rootLabel}"
                contentRole="Main"
                contentLabel="{i18n>Privacy_contentLabel}"/>
        </landmarkInfo>

        <ScrollContainer width="100%" height="100%" vertical="true">
            <VBox class="sapUiContentPadding" width="100%" fitContainer="true" renderType="Bare" justifyContent="Center" alignItems="Center">

                <!-- Main container with fixed width on large screens -->
                <VBox width="{= ${device>/system/phone} ? '90%' : '70%' }" class="sapUiMediumMarginTopBottom">

                    <!-- Section Template -->
                    <VBox class="sapUiCard sapUiSmallMargin sapUiPadding" renderType="Bare">
                        <Title text="1. Data Collection" level="H3" class="sapUiTitleColor sapUiTinyMarginBottom"/>
                        <Text text="We collect expense data you enter in the app. No personal information is transmitted to external servers. Optional info (like email or name) may be used only locally for personalization." wrapping="true"/>
                    </VBox>

                    <VBox class="sapUiCard sapUiSmallMargin sapUiPadding" renderType="Bare">
                        <Title text="2. Data Usage" level="H3" class="sapUiTitleColor sapUiTinyMarginBottom"/>
                        <Text text="Your data is used solely for app functionality, calculations, summaries, and reports. Helps improve the app experience and analytics locally." wrapping="true"/>
                    </VBox>

                    <VBox class="sapUiCard sapUiSmallMargin sapUiPadding" renderType="Bare">
                        <Title text="3. Data Sharing" level="H3" class="sapUiTitleColor sapUiTinyMarginBottom"/>
                        <Text text="We never sell or share your personal information with third parties. Data remains on your device unless you explicitly export or share it." wrapping="true"/>
                    </VBox>

                    <VBox class="sapUiCard sapUiSmallMargin sapUiPadding" renderType="Bare">
                        <Title text="4. Security Measures" level="H3" class="sapUiTitleColor sapUiTinyMarginBottom"/>
                        <Text text="Data is stored locally and securely on your device. We use encryption where applicable to protect sensitive information." wrapping="true"/>
                    </VBox>

                    <VBox class="sapUiCard sapUiSmallMargin sapUiPadding" renderType="Bare">
                        <Title text="5. Cookies and Tracking" level="H3" class="sapUiTitleColor sapUiTinyMarginBottom"/>
                        <Text text="The app does not use cookies or tracking scripts. Your activity stays private and local." wrapping="true"/>
                    </VBox>

                    <VBox class="sapUiCard sapUiSmallMargin sapUiPadding" renderType="Bare">
                        <Title text="6. Third-Party Services" level="H3" class="sapUiTitleColor sapUiTinyMarginBottom"/>
                        <Text text="If you connect optional third-party services (e.g., cloud backup), they may handle data according to their own privacy rules. You control any connection; nothing is shared automatically." wrapping="true"/>
                    </VBox>

                    <VBox class="sapUiCard sapUiSmallMargin sapUiPadding" renderType="Bare">
                        <Title text="7. Data Retention" level="H3" class="sapUiTitleColor sapUiTinyMarginBottom"/>
                        <Text text="Data remains on your device indefinitely until you delete it. No automatic transmission or retention on external servers." wrapping="true"/>
                    </VBox>

                    <VBox class="sapUiCard sapUiSmallMargin sapUiPadding" renderType="Bare">
                        <Title text="8. User Control" level="H3" class="sapUiTitleColor sapUiTinyMarginBottom"/>
                        <Text text="You can edit, delete, or export your expense data at any time. You are fully in control of what the app stores." wrapping="true"/>
                    </VBox>

                    <VBox class="sapUiCard sapUiSmallMargin sapUiPadding" renderType="Bare">
                        <Title text="9. Children’s Privacy" level="H3" class="sapUiTitleColor sapUiTinyMarginBottom"/>
                        <Text text="The app is not intended for children under 13. We do not knowingly collect data from minors." wrapping="true"/>
                    </VBox>

                    <VBox class="sapUiCard sapUiSmallMargin sapUiPadding" renderType="Bare">
                        <Title text="10. Changes to Privacy Policy" level="H3" class="sapUiTitleColor sapUiTinyMarginBottom"/>
                        <Text text="We may update the policy from time to time. Continued use of the app implies acceptance of changes." wrapping="true"/>
                    </VBox>

                    <VBox class="sapUiCard sapUiSmallMargin sapUiPadding" renderType="Bare">
                        <Title text="11. Contact Information" level="H3" class="sapUiTitleColor sapUiTinyMarginBottom"/>
                        <Text text="{= 'For questions, visit: ' + ${oApplicationConfigModel>/companyDetails/website} + ' or contact us via the app support feature.'}" wrapping="true"/>
                    </VBox>

                </VBox>
            </VBox>
        </ScrollContainer>
    </Page>
</mvc:View>
