<FlexBox
 visible="{=${oGlobalAIModel>/maintenance/isUnderMaintenance}}"
 direction="Column"
 alignItems="Center"
 justifyContent="Start"
 class="sapUiResponsiveMargin sapUiLargeMarginTop">


<FlexBox
    direction="Column"
    alignItems="Center"
    justifyContent="Center"
    width="100%"
    class="sapUiContentPadding sapUiSmallMargin">

    <Title
        text="{oGlobalAIModel>/maintenance/maintenancemessage}"
        level="H2"
        class="sapUiSmallMarginBottom"/>

    <Image
        src="images/loading.png"
        width="150px"
        densityAware="false"
        class="sapUiSmallMarginTop"/>

    <Button
        text="Refresh"
        type="Emphasized"
        press=".onRefresh"
        width="150px"
        class="sapUiLargeMarginTop"/>

</FlexBox>


</FlexBox>

<FlexBox
 visible="{
     parts: [
         'oGlobalAIModel>/ApplicationConfigurations/isApplicationDetailsLoaded',
         'oGlobalAIModel>/maintenance/isUnderMaintenance'
     ],
     formatter: '.formatter.fnHomeShowAppLoading'
 }" 
 direction="Column"
 alignItems="Center"
 justifyContent="Center"
 class="sapUiResponsiveMargin sapUiLargeMarginTop">
 

<Image
    src="images/loading.gif"
      width="100%"
    height="100%"
    densityAware="false"/>


</FlexBox>

 
</mvc:View>
